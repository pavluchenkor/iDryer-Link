# Переменные окружения для разработки iDryer

# Путь к flasher-portal для автоматического копирования прошивок
# Раскомментируйте и укажите свой путь, если используете flasher-portal
# IDRYER_FLASHER_PORTAL_PATH=/path/to/your/iDryerPortal/flasher-portal

# Пример для основного разработчика:
# IDRYER_FLASHER_PORTAL_PATH=/Users/ruslanpavlucenko/Projects/iDryerPortal/flasher-portal